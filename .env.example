# Kontaktformular – Gmail-SMTP-Versand
# Gmail-App-Passwort erstellen: https://myaccount.google.com/apppasswords
# (Voraussetzung: 2-Faktor-Authentifizierung aktiv)
# Echte Werte gehören in .env (ignoriert), NICHT in diese Datei!
NUXT_SMTP_USER=deine.adresse@gmail.com
NUXT_SMTP_PASS=dein-16-stelliges-app-passwort
NUXT_CONTACT_TO=konrad.thiemann@gmail.com

# Optional (Defaults sind bereits gesetzt):
# NUXT_SMTP_HOST=smtp.gmail.com
# NUXT_SMTP_PORT=465
